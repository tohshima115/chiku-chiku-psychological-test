---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'エセ心理学の「嬉しい言い換え」を身も蓋もなく本音に戻す診断テスト', ogImage } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@400;700;900&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
  </head>
  <body class="noise-overlay min-h-dvh bg-poka-bg text-gray-800" style="font-family: 'Zen Maru Gothic', 'Hiragino Maru Gothic ProN', 'BIZ UDGothic', sans-serif;">
    <main class="min-h-dvh pb-[env(safe-area-inset-bottom)]">
      <slot />
    </main>

    <footer class="border-t border-gray-100/50 py-6 text-center text-[10px] leading-relaxed text-gray-400">
      <p class="mx-auto max-w-xs px-4">
        このサイトはジョーク・エンタメ目的の診断テストです。科学的根拠はありません。結果はお遊びとしてお楽しみください。
      </p>
    </footer>
  </body>
</html>
